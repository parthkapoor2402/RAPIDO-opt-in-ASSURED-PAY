# Assured Pay MVP — environment reference
# Copy sections to frontend/.env.local and backend/.env (never commit real secrets).

# =============================================================================
# Frontend → frontend/.env.local
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_VERSION=0.1.0

# =============================================================================
# Backend → backend/.env
# =============================================================================
APP_NAME=Assured Pay API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HOST=0.0.0.0
PORT=8000

# Settlement policy
BUFFER_AMOUNT_INR=7
SMALL_EXCESS_CEILING_INR=10
SUSPICIOUS_THRESHOLD_INR=25
SETTLEMENT_POLICY_VERSION=0.1.0

# Recovery policy
GRACE_PERIOD_DAYS=7
MAX_UNPAID_BEFORE_HARD_BLOCK=2
DISPUTE_WINDOW_HOURS=24

# Grok / xAI (optional — assistive copy only, never settlement)
GROK_API_KEY=
GROK_COPY_ENABLED=false
GROK_API_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3-mini

# =============================================================================
# Playwright E2E (optional, root or CI)
# =============================================================================
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3099
# PLAYWRIGHT_PORT=3099
# PLAYWRIGHT_SKIP_WEBSERVER=1

# =============================================================================
# Production deployment (set in host dashboards, not committed)
# =============================================================================
# Vercel (frontend): NEXT_PUBLIC_API_URL=https://your-api.railway.app
# Railway/Render (backend): CORS_ORIGINS=https://your-app.vercel.app
